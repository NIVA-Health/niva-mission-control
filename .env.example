# NIVA Mission Control — environment configuration
#
# Data source selector. "trello" (default) uses the live Trello API.
# "mock" uses bundled sample data so you can preview the UI with no credentials.
DATA_SOURCE=trello

# --- Trello (required when DATA_SOURCE=trello) ---
# Create a key + token at https://trello.com/power-ups/admin (or https://trello.com/app-key)
TRELLO_API_KEY=
TRELLO_TOKEN=
# The board that holds your initiatives (the id in the board URL, or the short link)
TRELLO_BOARD_ID=

# Optional: seconds to cache Trello responses server-side (default 60)
DATA_REVALIDATE_SECONDS=60

# --- Shared "hidden cards" curation ---
# Comma-separated accounts allowed to hide/restore cards for ALL viewers.
# Fails closed: if this is empty, nobody can hide anything.
ADMIN_EMAILS=josh@nivahealth.com,ltchabvonga@nivahealth.com

# Local dev only: simulates the IAP-authenticated user, since there is no IAP
# in front of `npm run dev`. Set to an address listed in ADMIN_EMAILS to test
# the hide controls locally. Never set this in production.
DEV_USER_EMAIL=josh@nivahealth.com

# Optional: force the Firestore project when running locally with ADC.
# On Cloud Run this is detected automatically and can be left unset.
# FIRESTORE_PROJECT_ID=niva-hr-database
